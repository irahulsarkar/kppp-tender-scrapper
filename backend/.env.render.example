NODE_ENV=production
# Render injects PORT automatically. Keep this as fallback only.
PORT=5000

# Use your Vercel frontend URL(s), comma-separated if multiple.
CORS_ORIGIN=https://your-frontend.vercel.app

# Set this to your Render PostgreSQL Internal Database URL.
DATABASE_URL=postgres://user:password@hostname:5432/kppp_tenders

SCRAPE_URL=https://kppp.karnataka.gov.in
SCRAPE_HEADLESS=true
SCRAPE_TIMEOUT_MS=120000
SCRAPE_RETRY_ATTEMPTS=3
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_ON_START=true
CAPTCHA_MAX_ATTEMPTS=5
CAPTCHA_PROVIDER=tesseract
CAPTCHA_API_KEY=
PUPPETEER_EXECUTABLE_PATH=

HIGH_VALUE_ALERT_THRESHOLD=1000000
ENABLE_EMAIL_ALERTS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=

ENABLE_WHATSAPP_ALERTS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=
